{
  "rules": {
    "queues": {
      ".read": true,
      ".write": false, 
      "$standId": {
        ".validate": "newData.hasChildren(['estimatedWaitMin', 'queueLength', 'lastUpdated'])",
        "estimatedWaitMin": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "queueLength": {
          ".validate": "newData.isNumber() && newData.val() >= 0"
        },
        "velocity": {
          ".validate": "newData.isNumber()"
        }
      }
    },
    "presence": {
      ".read": "auth != null",
      "$crewId": {
        "$userId": {
          ".write": "auth != null && $userId === auth.uid",
          ".validate": "newData.hasChildren(['lat', 'lng', 'lastSeen'])"
        }
      }
    }
  }
}
